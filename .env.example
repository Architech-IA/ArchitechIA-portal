# ── Base de datos (PostgreSQL - Neon) ──────────────────────────────
# Obtén este string desde: https://neon.tech → tu proyecto → Connection String
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── NextAuth ───────────────────────────────────────────────────────
# Genera un secret con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=tu_secret_aleatorio_aqui

# URL de tu app desplegada en Vercel (sin barra final)
# En local: http://localhost:3000
NEXTAUTH_URL=https://tu-proyecto.vercel.app
